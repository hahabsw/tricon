{
  "name": "tricon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,colyseus\" --prefix-colors \"cyan,magenta\" \"next dev\" \"tsx watch src/server/index.ts\"",
    "dev:next": "next dev",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "next build",
    "build:colyseus": "tsup src/server/index.ts --platform node --format esm --out-dir dist/server --sourcemap",
    "build:artifacts": "npm run build && npm run build:colyseus",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.41",
    "@colyseus/schema": "^4.0.20",
    "@colyseus/ws-transport": "^0.17.13",
    "@pixi/react": "^8.0.5",
    "colyseus": "^0.17.9",
    "next": "16.1.4",
    "pixi.js": "^8.18.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
